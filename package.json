{
  "name": "@pyyupsk/fdu",
  "version": "0.0.0-beta.3",
  "description": "Ultra-fast, zero-dependency date-time library for JavaScript & TypeScript",
  "keywords": [
    "date",
    "datetime",
    "time",
    "timestamp",
    "dayjs",
    "moment",
    "date-fns",
    "lightweight",
    "immutable",
    "typescript",
    "i18n",
    "locale",
    "formatter",
    "parser",
    "timezone",
    "fdu",
    "fast",
    "zero-dependency",
    "utility",
    "javascript-library"
  ],
  "license": "MIT",
  "author": "Pongsakorn Thipayanate <contact@fasu.dev>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./locale/*": {
      "types": "./dist/locale/*.d.ts",
      "import": "./dist/locale/*.js",
      "require": "./dist/locale/*.cjs"
    },
    "./plugins/*": {
      "types": "./dist/plugins/*.d.ts",
      "import": "./dist/plugins/*.js",
      "require": "./dist/plugins/*.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "package.json"
  ],
  "scripts": {
    "bench": "vitest bench --run",
    "bench:update": "vitest bench --run | bun scripts/extract-benchmarks.ts",
    "build": "rimraf dist && tsdown",
    "docs:dev": "bun --cwd=docs run dev",
    "docs:build": "bun --cwd=docs run build",
    "format": "biome format --write",
    "lint": "biome check && eslint",
    "lint:fix": "biome check --fix && eslint --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/bun": "^1.3.12",
    "@types/luxon": "^3.7.1",
    "@vitest/coverage-v8": "^4.1.4",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "eslint": "^10.2.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "glob": "^13.0.6",
    "jiti": "^2.6.1",
    "luxon": "^3.7.2",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "picomatch": "^4.0.4",
    "rollup": "^4.60.1",
    "vite": "^7.3.2"
  }
}
